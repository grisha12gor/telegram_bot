import telebot
import random

TOKEN = "7948845009:AAGP2dbQ-IJaLYi9uy5juxQQAztVw1JAY9w"
bot = telebot.TeleBot(TOKEN)

games = {}

@bot.message_handler(commands=['start'])
def start(msg):
    games[msg.chat.id] = random.randint(1, 100)
    bot.send_message(msg.chat.id, "Игра началась! Я загадал число от 1 до 100. Угадывай!")

@bot.message_handler(func=lambda m: True)
def guess(msg):
    chat_id = msg.chat.id

    if chat_id not in games:
        games[chat_id] = random.randint(1, 100)
        bot.send_message(chat_id, "Начинаем новую игру! Угадывай число от 1 до 100.")

    try:
        n = int(msg.text)
    except:
        bot.send_message(chat_id, "Введи число.")
        return

    target = games[chat_id]

    if n < target:
        bot.send_message(chat_id, "Моё число больше.")
    elif n > target:
        bot.send_message(chat_id, "Моё число меньше.")
    else:
        bot.send_message(chat_id, "Угадал! Я загадал новое число — попробуй снова.")
        games[chat_id] = random.randint(1, 100)

bot.polling()

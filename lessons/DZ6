import asyncio
from aiogram import Bot, Dispatcher, types
from aiogram.filters import Command
from aiogram.types import InlineKeyboardMarkup, InlineKeyboardButton

TOKEN = "8597941396:AAFcizbo1ubZaS3p-xYr775wVR2pfN7BUYo"

bot = Bot(token=TOKEN)
dp = Dispatcher()

user_data = {}

@dp.message(Command("start"))
async def start(message: types.Message):
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="Заполнить анкету", callback_data="form_start")]
    ])

    await message.answer(
        "Привет! Заполни анкету о твоей любимой игре.",
        reply_markup=kb
    )

@dp.callback_query(lambda c: c.data == "form_start")
async def form_start(callback: types.CallbackQuery):
    user_data[callback.from_user.id] = {}

    await callback.message.answer("Как тебя зовут?")
    await callback.answer()

@dp.message()
async def form_process(message: types.Message):
    user_id = message.from_user.id

    if user_id not in user_data:
        return

    if "name" not in user_data[user_id]:
        user_data[user_id]["name"] = message.text
        await message.answer("Сколько тебе лет?")
        return

    if "age" not in user_data[user_id]:
        user_data[user_id]["age"] = message.text

        kb = InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="BeamNG.drive", callback_data="game_beamng")],
            [InlineKeyboardButton(text="SnowRunner", callback_data="game_snow")],
            [InlineKeyboardButton(text="Phasmophobia", callback_data="game_phasmo")],
            [InlineKeyboardButton(text="Minecraft", callback_data="game_mc")],
        ])

        await message.answer("Какая твоя любимая игра?", reply_markup=kb)
        return

@dp.callback_query(lambda c: c.data.startswith("game_"))
async def choose_game(callback: types.CallbackQuery):
    user_id = callback.from_user.id

    games = {
        "game_beamng": "BeamNG.drive",
        "game_snow": "SnowRunner",
        "game_phasmo": "Phasmophobia",
        "game_mc": "Minecraft"
    }

    user_data[user_id]["game"] = games[callback.data]

    name = user_data[user_id]["name"]
    age = user_data[user_id]["age"]
    game = user_data[user_id]["game"]

    await callback.message.answer(
        f"Анкета готова!\n\n"
        f"Имя: {name}\n"
        f"Возраст: {age}\n"
        f"Любимая игра: {game}"
    )

    await callback.answer()

    del user_data[user_id]

async def main():
    await dp.start_polling(bot)


if __name__ == "__main__":
    asyncio.run(main())
